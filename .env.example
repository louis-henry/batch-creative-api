# Copy to server/.env and fill in. Never commit a real .env.

# Text provider (post copy + style read + judge) — single gateway, model fallback.
OPENROUTER_API_KEY=

# Image providers — set at least one. With both, Gemini is primary and OpenAI is
# the failover (and Chaos mode can demo failover between them).
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional
PORT=8787
PUBLIC_BASE_URL=http://localhost:8787
# Restrict CORS to your web origin in production (omit to allow any origin).
# WEB_ORIGIN=https://your-web-app.vercel.app

# Note: the failover "chaos" demo is a per-request toggle in the UI, not an env var.
