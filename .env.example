# Copy to .env and fill in. Never commit .env.

# Text provider (copy + LLM-judge) — single gateway, model fallback.
OPENROUTER_API_KEY=

# Image providers — primary then failover.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Server
PORT=8787

# Reliability demo: when true, the primary image provider always fails,
# so failover to the secondary provider is observable end-to-end.
CHAOS=false
